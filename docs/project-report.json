          {
            "name": "packs/",
            "description": "17 个能力包目录（含 L2 Experiences + L3 Knowledge）"
          },
          {
            "name": "schemas/",
            "description": "JSON Schema 验证 (v1 + v2) + 健康度检查"
          },
          {
            "name": "reports/",
            "description": "健康仪表盘 (CHI/SQS/生命周期)"
          },
          {
            "name": ".github/",
            "description": "CI 门禁 (4 job 并行 + CHI 不降级)"
          }
        ],
        "direction": "foundation"
      }
