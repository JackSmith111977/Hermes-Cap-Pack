        "direction": "user-facing"
      },
      {
        "name": "Layer 2 — 工具层 Tools",
        "modules": [
          {
            "name": "scripts/cli/",
            "description": "CLI 入口 + 13 个命令 (install/remove/verify/list/upgrade/status/search/skill)"
          },
          {
            "name": "scripts/adapters/",
            "description": "HermesAdapter + OpenCodeAdapter + 多 Agent 安装"
          },
          {
            "name": "scripts/uca/",
            "description": "Parser + Protocol + Verifier + Dependency + 验证门禁"
          },
          {
            "name": "scripts/tests/",
            "description": "141 个测试 (9 个文件)"
          }
        ],
        "direction": "business-logic"
      },
      {
        "name": "Layer 1 — 基础设施层 Infrastructure",
        "modules": [
          {
            "name": "docs/",
            "description": "SDD 文档体系 (5 Epics / 16 Specs / 53 Stories)"
