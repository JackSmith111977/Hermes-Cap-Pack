          "install()",
          "uninstall()",
          "verify()",
          "update()"
        ]
      },
      {
        "module": "OpenCodeAdapter",
        "file": "scripts/adapters/opencode.py",
        "desc": "安装到 OpenCode CLI",
        "methods": [
          "install()",
          "format_convert()"
        ]
      },
      {
        "module": "SQS Engine",
