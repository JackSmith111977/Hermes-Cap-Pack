  "cli_commands": [
    {
      "command": "cap-pack install <dir>",
      "description": "从目录安装能力包"
    },
    {
      "command": "cap-pack install <dir> --dry-run",
      "description": "预览安装"
    },
    {
      "command": "cap-pack remove <name>",
      "description": "卸载能力包"
    },
    {
      "command": "cap-pack verify <name>",
      "description": "验证已安装的包"
    },
    {
      "command": "cap-pack list",
      "description": "列出已安装的能力包"
    },
    {
      "command": "cap-pack upgrade <name>",
      "description": "升级已安装的包"
    },
    {
      "command": "cap-pack upgrade --all",
      "description": "升级全部"
    },
    {
      "command": "cap-pack status",
      "description": "全局状态概览"
    },
    {
      "command": "cap-pack search <term>",
      "description": "搜索可用能力包"
    },
    {
      "command": "cap-pack inspect <dir>",
      "description": "查看包内容"
    },
    {
      "command": "cap-pack skill add <pack> <src>",
      "description": "添加 skill 到能力包"
    },
    {
      "command": "cap-pack skill remove <pack> <id>",
      "description": "从能力包移除 skill"
    },
    {
      "command": "cap-pack skill list <pack>",
      "description": "列出能力包内 skill"
    },
    {
      "command": "cap-pack skill update <pack> <id>",
      "description": "更新能力包内 skill"
    }
  ],
