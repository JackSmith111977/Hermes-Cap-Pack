          "--json",
          "--health",
          "--consolidate"
        ]
      },
      {
        "module": "Health Check",
        "file": "scripts/health-check.py",
        "desc": "6 KPI + CHI 综合健康指数",
        "methods": [
          "--json",
          "--gate"
        ]
      },
      {
        "module": "Merge Suggest",
        "file": "scripts/merge-suggest.py",
        "desc": "内容相似度分析 + 合并建议引擎",
