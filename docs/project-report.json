          "--prioritize"
        ]
      },
      {
        "module": "Validate Layers",
        "file": "scripts/validate-layers.py",
        "desc": "三层完整性检查",
        "methods": [
          "verify()"
        ]
      },
      {
        "module": "Project State",
        "file": "scripts/project-state.py",
        "desc": "统一状态机管理",
        "methods": [
          "verify()",
