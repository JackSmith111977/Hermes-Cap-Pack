{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes-agent.local/schemas/cap-pack-v1.json",
  "title": "Capability Pack v1",
  "description": "Schema for Hermes Capability Pack manifest files (cap-pack.yaml)",
  "type": "object",
  "required": ["name", "version", "type", "classification", "display_name", "description", "created", "updated"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,48}[a-z0-9]$",
      "description": "Module ID, lowercase with hyphens"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version MAJOR.MINOR.PATCH"
    },
    "type": {
      "type": "string",
      "enum": ["capability-pack"],
      "description": "Fixed value"
    },
    "classification": {
      "type": "string",
      "enum": ["domain", "toolset", "skill"],
      "description": "Module classification dimension"
    },
    "display_name": { "type": "string", "maxLength": 60 },
    "description": { "type": "string", "maxLength": 500 },
    "author": { "type": "string" },
    "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "compatibility": {
      "type": "object",
      "properties": {
        "agent_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["hermes", "claude-code", "codex-cli"] },
          "minItems": 1
        },
        "requires_mcp": { "type": "boolean", "default": false },
        "requires_network": { "type": "boolean", "default": false },
        "requires_env": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["agent_types"]
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "cap_packs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
            },
            "required": ["name", "version"]
          }
        },
        "system_packages": { "type": "array", "items": { "type": "string" } },
        "python_packages": { "type": "array", "items": { "type": "string" } },
        "node_packages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "path": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "description": { "type": "string", "maxLength": 200 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "experience_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "experiences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "type", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "path": { "type": "string" },
          "type": { "type": "string", "enum": ["pitfall", "decision-tree", "comparison", "lesson"] },
          "description": { "type": "string", "maxLength": 200 },
          "skill_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "transport": { "type": "string", "enum": ["stdio", "sse", "streamable-http"] },
          "tools": { "type": "array", "items": { "type": "string" } },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "oneOf": [
          { "required": ["command"] },
          { "required": ["url"] }
        ]
      }
    },
    "config_defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "hooks": {
      "type": "object",
      "properties": {
        "on_activate": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
        "on_deactivate": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
        "on_update": { "type": "array", "items": { "$ref": "#/definitions/hook" } }
      }
    }
  },
  "definitions": {
    "hook": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["shell", "notify", "python"] },
        "command": { "type": "string" },
        "message": { "type": "string" },
        "code": { "type": "string" }
      }
    }
  }
}
