{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes-agent.local/schemas/cap-pack-v2.json",
  "title": "Capability Pack v2 — Structured Capability Pack Manifest",
  "description": "Structured schema for Hermes Capability Pack manifest files (cap-pack.yaml). v2 adds integration, lifecycle, verification, and compatibility sections for external tools.",
  "type": "object",
  "required": [
    "name", "version", "type", "classification", "display_name",
    "description", "compatibility"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,48}[a-z0-9]$",
      "description": "Pack ID, lowercase with hyphens"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version MAJOR.MINOR.PATCH"
    },
    "type": {
      "type": "string",
      "enum": ["capability-pack"],
      "description": "Fixed value"
    },
    "classification": {
      "type": "string",
      "enum": ["domain", "toolset", "skill", "infrastructure"],
      "description": "Module classification dimension. 'infrastructure' for system-level packs like skill-quality."
    },
    "display_name": { "type": "string", "maxLength": 60 },
    "description": { "type": "string", "maxLength": 500 },
    "author": { "type": "string" },
    "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "emoji": { "type": "string", "maxLength": 4 },
    "category": { "type": "string" },
    "domain": { "type": "string" },
    "maintainer": { "type": "string" },

    "compatibility": {
      "type": "object",
      "required": ["agent_types"],
      "properties": {
        "agent_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["hermes", "claude-code", "codex-cli", "opencode"] },
          "minItems": 1
        },
        "hermes_version": {
          "type": "object",
          "properties": {
            "min": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
            "max": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
          }
        },
        "requires_mcp": { "type": "boolean", "default": false },
        "requires_network": { "type": "boolean", "default": false },
        "requires_env": { "type": "array", "items": { "type": "string" } }
      }
    },

    "dependencies": {
      "type": "object",
      "properties": {
        "cap_packs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
            },
            "required": ["name", "version"]
          }
        },
        "system_packages": { "type": "array", "items": { "type": "string" } },
        "python_packages": { "type": "array", "items": { "type": "string" } },
        "node_packages": { "type": "array", "items": { "type": "string" } }
      }
    },

    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "path": { "type": "string", "description": "Skill directory path (preferred)." },
          "source": { "type": "string", "description": "v1 backward-compatible alias for path." },
          "name": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "description": { "type": "string", "maxLength": 500 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "cluster": { "type": "string" },
          "sqs_target": { "type": "number", "minimum": 0, "maximum": 100 },
          "experience_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "experiences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "path": { "type": "string" },
          "type": { "type": "string", "enum": ["pitfall", "decision-tree", "comparison", "lesson", "experience"], "default": "experience" },
          "description": { "type": "string", "maxLength": 200 },
          "skill_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "transport": { "type": "string", "enum": ["stdio", "sse", "streamable-http"] },
          "tools": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "object", "additionalProperties": { "type": "string" } }
        },
        "oneOf": [
          { "required": ["command"] },
          { "required": ["url"] }
        ]
      }
    },

    "integration": {
      "type": "object",
      "description": "External integration components — scripts, monitors, gates, audits that operate without modifying core Hermes files.",
      "properties": {
        "locate": {
          "type": "object",
          "description": "Environment detection script configuration.",
          "properties": {
            "script": { "type": "string" },
            "required": { "type": "boolean", "default": true },
            "auto_detect": {
              "type": "object",
              "properties": {
                "targets": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["hermes_home", "source_type", "version", "tools", "skills_dirs", "profiles"] }
                },
                "fallback": { "type": "string" }
              }
            }
          },
          "required": ["script"]
        },
        "monitors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "script", "trigger"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
              "script": { "type": "string" },
              "trigger": { "type": "string", "enum": ["inotify", "cron", "post_operation", "startup"] },
              "schedule": { "type": "string" },
              "description": { "type": "string", "maxLength": 200 },
              "alert_on": { "type": "string", "enum": ["change", "quality_drop", "dependency_break"] }
            }
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "script", "hook_point"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
              "script": { "type": "string" },
              "hook_point": {
                "type": "string",
                "enum": ["pre_flight", "skill_create", "skill_edit", "skill_delete", "skill_install", "cron_audit"]
              },
              "blocking": { "type": "boolean", "default": false },
              "description": { "type": "string", "maxLength": 200 },
              "timeout_seconds": { "type": "integer", "minimum": 1, "default": 30 }
            }
          }
        },
        "audits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "script", "schedule"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
              "script": { "type": "string" },
              "schedule": { "type": "string" },
              "output_format": { "type": "string", "enum": ["json", "markdown", "feishu_card"] },
              "description": { "type": "string", "maxLength": 200 },
              "deliver_to": { "type": "string" }
            }
          }
        },
        "behaviors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "rule", "enforcement"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
              "rule": { "type": "string", "maxLength": 500 },
              "enforcement": { "type": "string", "enum": ["self_discipline", "skill_rule", "pre_flight_script", "memory"] },
              "trigger_condition": { "type": "string" },
              "description": { "type": "string", "maxLength": 200 }
            }
          }
        }
      }
    },

    "verification": {
      "type": "object",
      "properties": {
        "health_check_script": { "type": "string" },
        "sqs_targets": {
          "type": "object",
          "properties": {
            "minimum": { "type": "number", "minimum": 0, "maximum": 100, "default": 50 },
            "target": { "type": "number", "minimum": 0, "maximum": 100, "default": 70 }
          }
        },
        "signatures": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "lifecycle": {
      "type": "object",
      "properties": {
        "install": {
          "type": "object",
          "properties": {
            "pre_install": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "install": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "post_install": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "verify": { "type": "array", "items": { "$ref": "#/definitions/hook" } }
          }
        },
        "update": {
          "type": "object",
          "properties": {
            "pre_update": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "update": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "post_update": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "migrate": { "type": "array", "items": { "$ref": "#/definitions/hook" } }
          }
        },
        "uninstall": {
          "type": "object",
          "properties": {
            "pre_uninstall": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "uninstall": { "type": "array", "items": { "$ref": "#/definitions/hook" } },
            "rollback": { "type": "array", "items": { "$ref": "#/definitions/hook" } }
          }
        }
      }
    },

    "config_defaults": {
      "type": "object",
      "additionalProperties": true
    },

    "config_schema": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["string", "number", "boolean", "array", "object"] },
          "default": {},
          "description": { "type": "string" }
        },
        "required": ["type", "description"]
      }
    }
  },

  "definitions": {
    "hook": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["shell", "notify", "python"] },
        "command": { "type": "string" },
        "script": { "type": "string" },
        "message": { "type": "string" },
        "code": { "type": "string" },
        "workdir": { "type": "string" },
        "timeout": { "integer": "integer", "minimum": 1, "default": 60 },
        "condition": { "type": "string" }
      }
    }
  }
}
